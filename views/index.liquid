{% render 'partials/head.liquid' %}

 <main>

    <h1>Home</h1>
    <h2>Welkom bezoeker</h2>


    {% comment %} BLOEMENVELD COLLECTIE {% endcomment %}
    <section class="bloemenveld-collectie">
        <img src="/assets/collectie.svg" width="20"  alt="bloemicoon">
        <h3>Bloemenveld collectie</h3>
    </section>

    <p class="niks-gespaard-veldverkenner">Je hebt nog niks gespaard. Start de <span class="veldverkenner">Veldverkenner</span> om meer te weten te komen over wat er groeit en je collectie aan te vullen</p>


    {% comment %} VELD NIEWS {% endcomment %}
    <section class="veld-nieuws">
        <img src="/assets/nieuws.svg" width="20" alt="kranticoon">
        <h3>Veld nieuws</h3>    
    </section>


    {% comment %} NIEUWS BERICHTEN {% endcomment %}
    <article class="nieuws-berichten">
        <div class="details">
            <p class="bloemendveld">Bloemendveld</p>
            <p>4u geleden</p>
        </div>

        <div>
            <h4>De na bloei van de duizendblad</h4>
            <img src="/assets/duizendblad.png" width="280" alt="afbeelding van de duizendblad">
            <p>De duizendblad is nog maar even in bloei</p>
        </div>
    </article>

 </main>

 {% render 'partials/navbar.liquid' %}

{% render 'partials/foot.liquid' %}